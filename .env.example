# OpenAI-compatible access token (required for AI features)
# Add your provider token below
VITE_OPENAI_TOKEN=your_provider_token_here

# Optional: custom provider endpoint (e.g. Mimo/OpenAI-compatible gateway)
# Example: https://api.mimo.ai/v1
VITE_OPENAI_BASE_URL=

# Optional: model name for your provider
# Example: gpt-4o, gpt-4o-mini, or provider-specific model id
VITE_OPENAI_MODEL=gpt-4o

# Optional: dedicated vision model for image analysis (Palmistry)
VITE_OPENAI_VISION_MODEL=
